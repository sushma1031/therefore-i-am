<%- include("partials/header"); -%>

  <% if (status === "draft") { %>
    <div class="d-flex flex-wrap align-items-center gap-2 mt-4 px-5-percent">
      <a class="btn btn-primary btn-sm" href="/posts/<%= id %>/edit">Edit</a>
      <a class="btn btn-outline-secondary btn-sm" href="/posts/<%= id %>/history">History</a>
      <form action="/posts/<%= id %>/publish" method="post" class="d-inline">
        <button class="btn btn-outline-secondary btn-sm" type="submit">Publish</button>
      </form>
    </div>
  <% } %>

  <h1 class="title">
    <%= title %>
  </h1>
  <div class="px-5-percent">
    <div class="post-content pb-3 opacity-60">
      <i class="fa-solid fa-user opacity-75 small"></i>
      <span class="post-meta">
        <%= username %>
      </span>
      <% if (status === "published") { %>
        <i class="fa-solid fa-calendar opacity-75 small"></i>
        <span class="post-meta">
            <time class="local-date" datetime="<%= datePosted.utcStr %>" data-format="datePosted.format">
                <%= datePosted.utcStr.split("T")[0] %>
            </time>
        </span>
      <% } %>
      </div>
    <% if (imageURL) { %>
      <div class="post-image">
        <img src="<%= imageURL %>" alt="post image">
      </div>
      <p class="image-credit">Source: <%- imageSource %></p>
    <% } %>
    <div class="post-content py-4 text-responsive">
      <%- content %>
    </div>
  </div>
  <script src="/scripts/date.js" defer></script>
<%- include("partials/footer"); -%>
