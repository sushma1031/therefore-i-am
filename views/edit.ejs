<%- include("partials/header"); -%>
  <script>
    let prevContent = <%- JSON.stringify(content) %>
    tinymce.init({
      selector: "textarea",
      plugins: "anchor autolink codesample image link lists",
      toolbar:
        "undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link table mergetags | numlist bullist indent outdent | removeformat",
      setup: function (editor) {
        editor.on('init', function () {
          this.setContent(prevContent);
        });
      }
      });
  </script>
  <h1 class="title">Edit</h1>
  <form class="needs-validation edit-form" action="" method="post" enctype="multipart/form-data" novalidate>
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input type="text" class="form-control" name="title" id="title" value="<%= title %>">
    </div>
    <div class="mb-3">
      <label for="content" class="form-label">Post</label>
      <textarea class="form-control" name="content" id="content" rows="5" required></textarea>
      <div class="invalid-feedback" id="invalidFb"></div>
    </div>

    <input type="hidden" name="deleteImage" id="deleteImage" value="false">
    <div class="row mb-3">
      <div class="col">
        <label for="image" class="form-label">Change image</label>
        <input class="form-control" type="file" accept=".png,.jpg,.jpeg" name="image" id="image">
        <div class="mt-3 thumbnail">
          <img class="rounded thumbnail-img <%= thumbnail === '' ? 'd-none' : '' %>" width="200" height="125" src="<%= thumbnail %>">
          <button type="button" class="btn btn-sm btn-outline-danger mt-2 d-block <%= thumbnail === '' ? 'd-none' : '' %>" id="removeImage">Remove Image</button>
        </div>
      </div>
      <div class="col">
        <label for="imageSource" class="form-label">Source</label>
        <input type="text" class="form-control" name="imageSource" id="imageSource" placeholder="Eg: <a href=link> Artist </a> on <a href=link> Website </a>" value="<%= imageSource %>">
      </div>
    </div>

    <% if (status === "draft") { %>
      <div class="flex flex-wrap gap-2 align-items-center justify-content-start">
        <div class="btn-group">
          <button class="btn btn-primary" type="submit">Save</button>
          <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="visually-hidden">Toggle Dropdown</span>
          </button>
          <ul class="dropdown-menu">
            <li><button class="dropdown-item" type="submit" formaction="/posts/<%= id %>/publish">Publish</button></li>
          </ul>
        </div>
        <a href="/posts/drafts/<%= id %>" role="button" class="btn btn-outline-secondary">Preview</a>
      </div>
    <% } else { %>
        <button class="btn btn-primary" type="submit">Save Changes</button>
    <% } %>
  </form>
  <script src="/scripts/editValidation.js" type="module"></script>

  <%- include("partials/footer"); -%>
